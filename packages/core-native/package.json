{
  "name": "@markdown-media/core",
  "version": "1.0.0",
  "description": "Native Node.js bindings for mdm-core Rust parser (HWP, legal, dates)",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "mdm-core",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "optionalDependencies": {
    "@markdown-media/core-darwin-arm64": "1.0.0",
    "@markdown-media/core-darwin-x64": "1.0.0",
    "@markdown-media/core-linux-x64-gnu": "1.0.0",
    "@markdown-media/core-linux-arm64-gnu": "1.0.0"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "node test/smoke.mjs",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seunghan91/markdown-media"
  }
}
