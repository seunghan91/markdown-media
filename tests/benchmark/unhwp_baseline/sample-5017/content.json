                    "background_color": null
                  }
                }
              },
              {
                "Text": {
                  "text": "는 먼저 글 문서 파일 형식 5.0에 관하여 설명한 후, 글 97 문서 파일 형식, HWPML에 관하여 설명한다. 각 형식에 대한 설명은 문서 파일 형식 내의 주요한 자료 형식 및 파일 구조, 레코드 구조에 대해서 설명한다.",
                  "style": {
                    "bold": false,
                    "italic": false,
                    "underline": false,
                    "strikethrough": false,
                    "superscript": false,
                    "subscript": false,
                    "font_name": "바탕",
